# Sao chép file này thành .env rồi điền khóa API.
# OpenRouter (tương thích chuẩn OpenAI). Lấy key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# id model trên OpenRouter, ví dụ:
#   anthropic/claude-haiku-4.5    (mặc định: nhanh, rẻ)
#   anthropic/claude-sonnet-4.6   (mạnh hơn)
#   openai/gpt-4o-mini
OPENROUTER_MODEL=anthropic/claude-haiku-4.5

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
